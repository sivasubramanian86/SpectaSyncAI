# ============================================================
# SpectaSyncAI — Environment Configuration
# Copy this file:  cp .env.example .env
# NEVER commit .env to version control (.gitignore already excludes it)
# ============================================================

# ── Google Cloud (Vertex AI — NO API KEY REQUIRED) ──────────────────────────
# Authentication: Application Default Credentials (ADC)
# Local:  gcloud auth application-default login
# Cloud Run: Automatic via attached Service Account (no extra config)

GOOGLE_CLOUD_PROJECT=spectasync-prod            # Your GCP project ID
GOOGLE_CLOUD_LOCATION=asia-southeast1           # Vertex AI region (closest to South/Southeast Asia)
GOOGLE_GENAI_USE_VERTEXAI=1                     # Tells google-adk to use Vertex AI, not AI Studio

# ── Model Configuration ─────────────────────────────────────────────────────
# These are passed to LlmAgent(model=...) in each agent file.
# Both models must be available in your GOOGLE_CLOUD_LOCATION region.
# Gemini 2.5 Pro  → reasoning-heavy agents (Orchestrator, Prediction, Crisis Tier-2)
# Gemini 2.5 Flash → speed-critical agents (Vision, Queue, Experience, Rumor)
MODEL_PRO=gemini-2.5-pro-preview-03-25
MODEL_FLASH=gemini-2.5-flash-preview-04-17

# ── AlloyDB (Production RAG Vector Store) ───────────────────────────────────
# Leave DATABASE_URL empty to run in PROTOTYPE MODE (in-memory cosine similarity)
# For production: deploy AlloyDB cluster + AlloyDB Auth Proxy, then set below.
# Format: postgresql+asyncpg://USER:PASSWORD@/DBNAME?host=/tmp/alloydb-proxy
DATABASE_URL=

# AlloyDB connection details (used by infra/alloydb_setup.sql and memory.py)
ALLOYDB_CLUSTER=spectasync-cluster
ALLOYDB_INSTANCE=spectasync-primary
ALLOYDB_DATABASE=spectasync
ALLOYDB_USER=spectasync_app

# ── MCP Server (FastMCP Toolbox) ────────────────────────────────────────────
# URL where the FastMCP SSE server is listening.
# Local dev: http://localhost:8001/sse
# Cloud Run: https://spectasync-mcp-<hash>-as.a.run.app/sse
MCP_SERVER_URL=http://localhost:8001/sse

# ── API / CORS ───────────────────────────────────────────────────────────────
# Add your Cloud Run frontend URL here when deployed.
# Multiple origins: comma-separated
CORS_ORIGINS=http://localhost:5173

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                                  # DEBUG | INFO | WARNING | ERROR

# ============================================================
# QUICKSTART CHECKLIST (local dev):
# 1. gcloud auth application-default login
# 2. Set GOOGLE_CLOUD_PROJECT to your project ID above
# Database Configuration
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
USE_ALLOYDB=false # Set to false to use local seed data and save GCP credits
# 4. python scripts/start_local.py
# ============================================================
