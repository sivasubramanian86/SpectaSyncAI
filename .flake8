[flake8]
max-line-length = 88
extend-ignore = E203, W503, E501, E402
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    node_modules,
    dist,
    .gemini,
    brain,
    scratch,
    .system_generated
max-complexity = 12
per-file-ignores =
    # Suppress unused imports in __init__.py files
    __init__.py: F401
    # Allow long test strings
    tests/*: E501
